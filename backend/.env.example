# HR智能简历筛选系统 环境配置
# 复制此文件为 .env 并填入实际值

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=hr_screening

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 服务器
SERVER_HOST=127.0.0.1
SERVER_PORT=8765

# 调试模式（开发时设为 true）
DEBUG=true
